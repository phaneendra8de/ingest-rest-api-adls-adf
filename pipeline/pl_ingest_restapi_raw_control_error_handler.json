{
	"name": "pl_ingest_restapi_raw_control_error_handler",
	"properties": {
		"activities": [
			{
				"name": "act_update_failure_log",
				"type": "Script",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"linkedServiceName": {
					"referenceName": "ls_postgres_metadata",
					"type": "LinkedServiceReference"
				},
				"typeProperties": {
					"scripts": [
						{
							"type": "Query",
							"text": {
								"value": "UPDATE ingestion_audit\nSET \n    status = 'FAILED',\n    end_time = CURRENT_TIMESTAMP,\n    error_message = '@{pipeline().parameters.p_error_message}'\nWHERE run_id = '@{pipeline().parameters.p_run_id}';",
								"type": "Expression"
							}
						}
					],
					"scriptBlockExecutionTimeout": "02:00:00"
				}
			}
		],
		"parameters": {
			"p_run_id": {
				"type": "string"
			},
			"p_pipeline_name": {
				"type": "string"
			},
			"p_error_message": {
				"type": "string"
			}
		},
		"annotations": []
	}
}