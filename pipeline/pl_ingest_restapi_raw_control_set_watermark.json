{
	"name": "pl_ingest_restapi_raw_control_set_watermark",
	"properties": {
		"activities": [
			{
				"name": "act_update_watermark",
				"type": "Script",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"linkedServiceName": {
					"referenceName": "ls_postgres_metadata",
					"type": "LinkedServiceReference"
				},
				"typeProperties": {
					"scripts": [
						{
							"type": "Query",
							"text": "UPDATE ingestion_watermark\nSET \n    last_watermark = '@{pipeline().parameters.p_new_watermark}',\n    updated_at = CURRENT_TIMESTAMP\nWHERE source_name = '@{pipeline().parameters.p_source_name}';"
						}
					],
					"scriptBlockExecutionTimeout": "02:00:00"
				}
			}
		],
		"parameters": {
			"p_source_name": {
				"type": "string"
			},
			"p_new_watermark": {
				"type": "string"
			}
		},
		"annotations": []
	}
}